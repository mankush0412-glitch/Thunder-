# =============================================================
# Thunder Bot — Render Deployment Config
# Sirf ye 6 cheezein bharo, baki sab automatic hai
# =============================================================

# ── TELEGRAM API (https://my.telegram.org/apps) ───────────────
API_ID=YOUR_API_ID_HERE
API_HASH=YOUR_API_HASH_HERE

# ── BOT TOKEN (@BotFather se) ─────────────────────────────────
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# ── STORAGE CHANNEL (Private channel ID, bot admin hona chahiye)
# ID format: -1001234567890
BIN_CHANNEL=YOUR_BIN_CHANNEL_ID_HERE

# ── OWNER ID (@userinfobot se apna ID lo) ────────────────────
OWNER_ID=YOUR_TELEGRAM_USER_ID_HERE

# ── MONGODB (mongodb.com/atlas se free cluster) ───────────────
DATABASE_URL=YOUR_MONGODB_URL_HERE

# =============================================================
# FQDN aur HAS_SSL mat likho — Render se AUTOMATIC milega
# Bot khud RENDER_EXTERNAL_URL padhta hai
# =============================================================

# ── OPTIONAL ──────────────────────────────────────────────────
MAX_BATCH_FILES=200
SET_COMMANDS=True
PING_INTERVAL=840
PORT=10000
NO_PORT=True
